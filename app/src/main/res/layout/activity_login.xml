<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="50dp"
        android:paddingBottom="40dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="-28dp"
            android:layout_marginEnd="-28dp"
            android:layout_marginBottom="10dp"
            android:paddingBottom="8dp">
            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/voteit_pinicon"
                android:scaleType="fitCenter"
                android:layout_marginBottom="14dp"
                android:contentDescription="VoteIt logo"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VoteIt"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FF5252"
                android:letterSpacing="0.05"
                android:layout_marginBottom="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_tagline"
                android:textSize="13sp"
                android:textColor="#FF5252"/>
        </LinearLayout>
        <TextView android:id="@+id/loginTitle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/login_title_login" android:textSize="22sp"
            android:textStyle="bold" android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/loginSubtitle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/login_subtitle_login" android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="28dp"/>
        <TextView android:id="@+id/usernameLabel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/login_label_username" android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="6dp" android:visibility="gone"/>
        <androidx.cardview.widget.CardView android:id="@+id/containerUsername"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginBottom="14dp" android:visibility="gone"
            app:cardCornerRadius="12dp" app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">
            <EditText android:id="@+id/etUsername"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@null" android:hint="@string/login_hint_username"
                android:inputType="text" android:maxLines="1"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant" android:textSize="15sp"/>
        </androidx.cardview.widget.CardView>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/login_label_email" android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="6dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginBottom="14dp" app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:cardBackgroundColor="?attr/colorSurfaceVariant">
            <EditText android:id="@+id/etEmail"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@null" android:hint="@string/login_hint_email"
                android:inputType="textEmailAddress" android:maxLines="1"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant" android:textSize="15sp"/>
        </androidx.cardview.widget.CardView>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="@string/login_label_password" android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="6dp"/>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginBottom="32dp" app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:cardBackgroundColor="?attr/colorSurfaceVariant">
            <EditText android:id="@+id/etPassword"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:background="@null" android:hint="@string/login_hint_password"
                android:inputType="textPassword" android:maxLines="1"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant" android:textSize="15sp"/>
        </androidx.cardview.widget.CardView>
        <Button android:id="@+id/btnAction"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="@string/login_btn_login" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold"
            android:backgroundTint="#FF5252" android:stateListAnimator="@null"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.Button"/>
        <Button android:id="@+id/btnSwitch"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="@string/login_switch_to_register" android:textColor="#FF5252"
            android:textSize="12sp" android:backgroundTint="?attr/colorSurfaceVariant"
            android:stateListAnimator="@null" android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button"/>
        <Button android:id="@+id/btnBack"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="@string/login_back"
            android:textColor="?attr/colorOnSurfaceVariant" android:textSize="13sp"
            android:backgroundTint="?attr/colorSurfaceVariant"
            android:stateListAnimator="@null" android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>
</ScrollView>