<?xml version="1.0" encoding="utf-8"?>
<!--
    Search bottom sheet — shown when the user taps the search pill in activity_main.
    Contains: pill input, search button, and a scrollable results list.
    Styled to match the white-card / red-accent aesthetic of the rest of the app.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp"
    android:background="?attr/colorSurface"
    android:clipChildren="false" android:clipToPadding="false">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="?attr/colorOnSurfaceVariant"
        android:alpha="0.3"/>

    <!-- Sheet title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/search_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="14dp"/>

    <!-- Input row: pill card + search button side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <!-- Pill input -->
        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="@string/search_hint_city"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@null"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch"/>

        </androidx.cardview.widget.CardView>

        <!-- Search button — square pill, red -->
        <Button
            android:id="@+id/searchGoBtn"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="@string/search_go"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF5252"
            android:stateListAnimator="@null"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

    <!-- Divider above results -->
    <View
        android:id="@+id/searchDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.08"
        android:visibility="gone"/>

    <!-- Results list — hidden until a search returns results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchResultsList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false"
        android:visibility="gone"/>

    <!-- Empty / loading state label -->
    <TextView
        android:id="@+id/searchStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp"
        android:visibility="gone"/>

</LinearLayout>