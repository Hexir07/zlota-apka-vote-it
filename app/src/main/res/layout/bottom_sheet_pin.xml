<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="28dp"
    android:background="?attr/colorSurface">


    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="?attr/colorOnSurfaceVariant"
        android:alpha="0.3"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/pinDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/pin_default_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:ellipsize="end"/>

        <!-- Ulubione -->
        <TextView
            android:id="@+id/pinFavBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="♡"
            android:textSize="20sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginStart="4dp"
            android:background="@null"/>

        <!-- Downvote -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#33FF5252"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textSize="11sp"
                android:textColor="#FF5252"/>

            <TextView
                android:id="@+id/pinDownvoteCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FF5252"/>
        </LinearLayout>

        <!-- Upvote -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#334CAF50"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textSize="11sp"
                android:textColor="#4CAF50"/>

            <TextView
                android:id="@+id/pinUpvoteCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"/>
        </LinearLayout>


        <TextView
            android:id="@+id/pinClearVoteBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:background="?attr/colorSurfaceVariant"
            android:visibility="gone"/>

    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.08"
        android:layout_marginBottom="14dp"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/pinDescCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">

        <TextView
            android:id="@+id/pinDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:text="@string/pin_no_desc"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"/>

    </androidx.cardview.widget.CardView>


    <LinearLayout
        android:id="@+id/pinAuthorRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/pinAuthorAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="?"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#FFCCCC"/>

        <TextView
            android:id="@+id/pinAuthorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/pin_unknown_author"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp">

        <Button
            android:id="@+id/pinDeleteBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#22FF5252"
            android:stateListAnimator="@null"
            android:text="▼  Downvote"
            android:textColor="#FF5252"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="#FF5252"
            app:strokeWidth="1.5dp"/>

        <Button
            android:id="@+id/pinNavigateBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#224CAF50"
            android:stateListAnimator="@null"
            android:text="▲  Upvote"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="#4CAF50"
            app:strokeWidth="1.5dp"/>

    </LinearLayout>


    <Button
        android:id="@+id/pinOwnerDeleteBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:visibility="gone"
        android:text="@string/pin_delete_btn"
        android:textColor="#CF6679"
        android:textSize="13sp"
        android:textStyle="bold"
        android:backgroundTint="#22B00020"
        android:stateListAnimator="@null"
        app:strokeColor="#CF6679"
        app:strokeWidth="1dp"/>

</LinearLayout>